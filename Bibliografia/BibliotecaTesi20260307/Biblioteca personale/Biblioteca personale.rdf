    <bib:Article rdf:about="https://rivisteopen.unimc.it/index.php/cap-cult/article/view/714">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <dc:title>Il capitale culturale. Studies on the Value of Cultural Heritage</dc:title>
                <dc:identifier>DOI 10.13138/2039-2362/714</dc:identifier>
                <prism:number>9</prism:number>
                <dc:identifier>ISSN 2039-2362</dc:identifier>
            </bib:Journal>
        </dcterms:isPartOf>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Parri</foaf:surname>
                        <foaf:givenName>Barbara Sibilio</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Manetti</foaf:surname>
                        <foaf:givenName>Giacomo</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
