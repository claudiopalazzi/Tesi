    <bib:Article rdf:about="https://doi.org/10.1093/geroni/igz029">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:2399-5300"/>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Kononova</foaf:surname>
                        <foaf:givenName>Anastasia</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Joshi</foaf:surname>
                        <foaf:givenName>Pradnya</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
