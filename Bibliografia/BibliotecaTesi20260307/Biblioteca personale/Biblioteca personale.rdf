    <bib:Article rdf:about="#item_499">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:2340-8170"/>
        <dc:publisher>
            <foaf:Organization>
               <foaf:name>University of Deusto</foaf:name>
