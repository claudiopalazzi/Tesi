    <bib:Article rdf:about="https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1083-6101.1997.tb00072.x">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <prism:volume>3</prism:volume>
                <dc:title>Journal of Computer-Mediated Communication</dc:title>
                <dc:identifier>DOI https://doi.org/10.1111/j.1083-6101.1997.tb00072.x</dc:identifier>
