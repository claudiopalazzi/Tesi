    <bib:Article rdf:about="https://rivisteopen.unimc.it/index.php/cap-cult/article/view/736">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <dc:title>Il capitale culturale. Studies on the Value of Cultural Heritage</dc:title>
                <dc:identifier>DOI 10.13138/2039-2362/736</dc:identifier>
