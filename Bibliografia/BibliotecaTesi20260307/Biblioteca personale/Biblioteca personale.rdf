    <bib:Article rdf:about="https://www.sciencedirect.com/science/article/pii/S2949916X24000045">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:2949-916X"/>
        <bib:authors>
            <rdf:Seq>
